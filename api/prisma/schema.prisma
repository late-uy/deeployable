// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
	provider = "prisma-client-js"
}

datasource db {
	provider = "sqlite"
	url      = env("DATABASE_URL")
}

model User {
	id           Int      @id @default(autoincrement())
	email        String   @unique
	passwordHash String
	role         UserRole
	createdAt    DateTime @default(now())
}

enum UserRole {
	root
	admin
	viewer
}

model Project {
	id           Int      @id @default(autoincrement())
	name         String
	provider     String?
	repoUrl      String
	branch       String
	buildCmd     String
	startCmd     String
	runtimePort  Int
	createdById  Int?

	environments Environment[]
	deploys      Deploy[]
	domains      Domain[]
}

model Environment {
	id              Int      @id @default(autoincrement())
	projectId       Int
	name            String
	subdomainPrefix String
	envVars         Json
	activeSlot      String   @default("a")

	project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
	deploys Deploy[]
}

model Domain {
	id        Int      @id @default(autoincrement())
	projectId Int
	host      String   @unique
	type      String
	verifiedAt DateTime?

	project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Deploy {
	id            Int      @id @default(autoincrement())
	projectId     Int
	environmentId Int
	sha           String
	status        DeployStatus
	startedAt     DateTime
	finishedAt    DateTime?
	logsPtr       String

	project     Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
	environment Environment @relation(fields: [environmentId], references: [id], onDelete: Cascade)
}

enum DeployStatus {
	queued
	running
	success
	failed
}
